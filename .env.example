# ─────────────────────────────────────────────────────────────────────────────
# AIPULS Portal — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Absolute path to neuronews.db.
#
# LOCAL dev (default — relative to portal.py, no need to set):
#   DB_PATH=./neuronews.db
#
# Vercel (bundle db in repo root, Vercel deploys it to /var/task/):
#   DB_PATH=/var/task/neuronews.db
#
# Vercel + writable copy in /tmp (for agents that write):
#   DB_PATH=/tmp/neuronews.db
#   (copy the file at cold-start — see api/index.py comments)
#
# Railway / Render / Fly.io (mount a persistent volume at e.g. /data):
#   DB_PATH=/data/neuronews.db
#
DB_PATH=/var/task/neuronews.db

# Public base URL of the deployed site — no trailing slash.
# Used in: canonical meta tags, og:image URLs, sitemap.xml, email links.
#
# Examples:
#   SITE_URL=https://aipuls.vercel.app
#   SITE_URL=https://aipuls.pl
#   SITE_URL=https://your-app.railway.app
#
# Leave empty for local development (falls back to http://localhost:PORT).
SITE_URL=https://aipuls.vercel.app

# ── Optional ──────────────────────────────────────────────────────────────────

# Resend API key for sending welcome emails to new newsletter subscribers.
# Free tier: 3 000 emails/month.
# Get key at: https://resend.com/api-keys
# If not set, subscribers are saved to DB silently (no email sent).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Listening port for portal.py (default: 8081).
# Only needed when running portal.py directly or via server.js.
PORT=8081

# Internal port portal.py listens on when behind the Express wrapper.
# server.js uses this to know where to proxy requests.
# Must match PORT above when running portal.py standalone.
PORTAL_PORT=8081

# Python executable — change if your system uses a different path.
# PYTHON=python3.11
PYTHON=python3

# Ollama inference URL for scout_agent.py and writer_agent.py.
# Default: http://localhost:11434/api/generate
# OLLAMA_URL=http://ollama:11434/api/generate
